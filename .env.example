# ── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# Local dev:   postgresql://postgres:postgres@localhost:5432/corpus
# Neon:        postgresql://user:password@ep-xxx.region.aws.neon.tech/corpus?sslmode=require
# Vercel PG:   postgres://user:password@host/db (copy from Vercel dashboard)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/corpus"

# Required when DATABASE_URL uses a connection pooler (e.g. Neon, pgBouncer).
# Set this to the direct (non-pooled) connection string.
# If you're not using a pooler, set this to the same value as DATABASE_URL.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/corpus"

# ── API Keys ────────────────────────────────────────────────────────────────
# Semantic Scholar — optional. Raises rate limit from 100 req/5min to 1 req/s.
# Register at: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# CORE — required to enable the CORE adapter (free).
# Register at: https://core.ac.uk/services/api
CORE_API_KEY=

# CrossRef — add your email for Polite Pool access (faster, higher limits).
CROSSREF_CONTACT_EMAIL=you@example.com

# ── Security ────────────────────────────────────────────────────────────────
# Protects POST /api/fetch. Leave empty to allow unauthenticated (fine for local dev).
FETCH_SECRET=

# Protects GET|POST /api/cron. Vercel sends this as: Authorization: Bearer <secret>
# Falls back to FETCH_SECRET if not set. Generate with: openssl rand -hex 32
CRON_SECRET=
